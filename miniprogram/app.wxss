page {
  background: linear-gradient(180deg, #0a0a1a 0%, #121225 50%, #0a0a1a 100%);
  min-height: 100vh;
  color: #e0e0f0;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.container {
  padding: 32rpx;
  min-height: 100vh;
}

.stars-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 0;
}

.card {
  background: rgba(20, 20, 45, 0.8);
  border: 1rpx solid rgba(201, 160, 80, 0.2);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  backdrop-filter: blur(10px);
}

.btn-primary {
  background: linear-gradient(135deg, #c9a050 0%, #e0b868 100%);
  color: #1a1a2e;
  border-radius: 50rpx;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}

.btn-outline {
  border: 1rpx solid rgba(201, 160, 80, 0.5);
  color: #c9a050;
  border-radius: 50rpx;
  padding: 22rpx 46rpx;
  font-size: 28rpx;
  text-align: center;
}

.text-gold {
  color: #c9a050;
}

.text-dim {
  color: #8888a0;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #e0e0f0;
  margin-bottom: 20rpx;
}
