.fortune-page {
  min-height: 100vh;
  background: #0a0a1a;
  padding: 24rpx;
  box-sizing: border-box;
}

.date-section {
  text-align: center;
  padding: 24rpx 0;
}

.date-text {
  font-size: 32rpx;
  color: #e0e0f0;
}

.ganzhi-text {
  display: block;
  font-size: 24rpx;
  color: #c9a050;
  margin-top: 8rpx;
  letter-spacing: 4rpx;
}

.loading-section {
  text-align: center;
  padding: 100rpx 0;
  color: #a0a0c0;
}

.overall-section {
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  text-align: center;
}

.score-circle {
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(135deg, rgba(201, 160, 80, 0.3), rgba(201, 160, 80, 0.1));
  border-radius: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24rpx;
}

.score-number {
  font-size: 64rpx;
  font-weight: 700;
  color: #c9a050;
}

.score-label {
  font-size: 24rpx;
  color: #a0a0c0;
  margin-top: 8rpx;
}

.phrase {
  font-size: 30rpx;
  color: #e0e0f0;
  line-height: 1.6;
  margin-top: 16rpx;
}

.chart-info {
  font-size: 24rpx;
  color: #8888a0;
  margin-top: 12rpx;
}

.dimension-section {
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.dimension-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.dimension-icon {
  width: 40rpx;
  font-size: 28rpx;
}

.dimension-label {
  width: 80rpx;
  font-size: 26rpx;
  color: #a0a0c0;
}

.score-bar {
  flex: 1;
  height: 16rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 8rpx;
  margin: 0 16rpx;
}

.score-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.5s;
}

.score-fill.love {
  background: linear-gradient(90deg, #f05050, #f08080);
}

.score-fill.career {
  background: linear-gradient(90deg, #5080f0, #80a0f0);
}

.score-fill.wealth {
  background: linear-gradient(90deg, #c9a050, #d0b060);
}

.score-fill.health {
  background: linear-gradient(90deg, #50c080, #80d0a0);
}

.dimension-score {
  width: 60rpx;
  font-size: 24rpx;
  color: #e0e0f0;
  text-align: right;
}

.yiji-section {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.yi-box, .ji-box {
  flex: 1;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 24rpx;
}

.yiji-title {
  display: block;
  font-size: 28rpx;
  color: #c9a050;
  margin-bottom: 16rpx;
  text-align: center;
}

.yiji-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.yi-item {
  font-size: 24rpx;
  color: #80c080;
  background: rgba(128, 192, 128, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  text-align: center;
}

.ji-item {
  font-size: 24rpx;
  color: #c08080;
  background: rgba(192, 128, 128, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  text-align: center;
}

.lucky-section {
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.lucky-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.lucky-icon {
  width: 40rpx;
  font-size: 28rpx;
}

.lucky-label {
  width: 140rpx;
  font-size: 26rpx;
  color: #a0a0c0;
}

.lucky-value {
  font-size: 28rpx;
  color: #c9a050;
  font-weight: 500;
}

.checkin-section {
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.checkin-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.checkin-title {
  font-size: 28rpx;
  color: #e0e0f0;
}

.checkin-stats {
  display: flex;
  gap: 24rpx;
}

.stat-item {
  font-size: 24rpx;
  color: #a0a0c0;
}

.checkin-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #c9a050, #a07830);
  color: #fff;
  border: none;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.checkin-btn.disabled {
  background: rgba(128, 128, 128, 0.3);
  color: #888;
}

.reward-tip {
  text-align: center;
  margin-top: 16rpx;
  color: #c9a050;
  font-size: 24rpx;
}

.share-btn {
  width: 100%;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.1);
  color: #e0e0f0;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 40rpx;
  font-size: 28rpx;
  margin-bottom: 24rpx;
}

.ad-banner {
  width: 100%;
  margin-top: 24rpx;
}