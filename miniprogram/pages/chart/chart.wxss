.login-tip {
  text-align: center;
  padding: 80rpx 0;
  margin-top: 40rpx;
}

.tip-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.tip-title {
  font-size: 32rpx;
  color: #e0e0f0;
  margin-bottom: 40rpx;
}

.match-header {
  text-align: center;
  padding: 40rpx 0 32rpx;
}

.header-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #c9a050;
  letter-spacing: 8rpx;
}

.header-sub {
  font-size: 26rpx;
  color: #8888a0;
  margin-top: 8rpx;
}

.match-type-selector {
  margin-bottom: 32rpx;
}

.type-label {
  font-size: 26rpx;
  color: #8888a0;
  margin-bottom: 16rpx;
}

.type-row {
  display: flex;
  gap: 16rpx;
}

.type-item {
  flex: 1;
  background: rgba(20, 20, 45, 0.6);
  border: 1rpx solid rgba(201, 160, 80, 0.2);
  border-radius: 16rpx;
  padding: 20rpx 16rpx;
  text-align: center;
}

.type-item.active {
  background: rgba(201, 160, 80, 0.15);
  border-color: #c9a050;
}

.type-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #e0e0f0;
  margin-bottom: 6rpx;
}

.type-desc {
  font-size: 20rpx;
  color: #8888a0;
}

.action-cards {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.action-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: rgba(20, 20, 45, 0.8);
  border: 1rpx solid rgba(201, 160, 80, 0.2);
  border-radius: 20rpx;
  padding: 32rpx;
}

.action-card.primary {
  background: linear-gradient(135deg, rgba(30, 30, 60, 0.9) 0%, rgba(40, 40, 70, 0.95) 100%);
  border-color: rgba(201, 160, 80, 0.4);
}

.action-icon {
  font-size: 48rpx;
}

.action-content {
  flex: 1;
}

.action-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #e0e0f0;
  margin-bottom: 6rpx;
}

.action-desc {
  font-size: 24rpx;
  color: #8888a0;
}

.action-arrow {
  font-size: 32rpx;
  color: #c9a050;
}

.coming-tag {
  font-size: 20rpx;
  color: #666680;
  background: rgba(255, 255, 255, 0.05);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.match-history {
  margin-top: 20rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-item {
  background: rgba(20, 20, 45, 0.6);
  border: 1rpx solid rgba(201, 160, 80, 0.15);
  border-radius: 16rpx;
  padding: 24rpx;
}

.history-users {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.user-name {
  font-size: 28rpx;
  color: #e0e0f0;
  font-weight: 500;
}

.vs {
  color: #c9a050;
  font-size: 20rpx;
}

.history-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.match-type-tag {
  font-size: 20rpx;
  color: #c9a050;
  background: rgba(201, 160, 80, 0.15);
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}

.match-type-tag.love {
  color: #e06060;
  background: rgba(224, 96, 96, 0.15);
}

.match-type-tag.career {
  color: #6090c8;
  background: rgba(96, 144, 200, 0.15);
}

.history-score {
  font-size: 24rpx;
  color: #c9a050;
  font-weight: 600;
}

.history-status {
  font-size: 22rpx;
  color: #8888a0;
  margin-left: auto;
}

.history-status.accepted {
  color: #50c878;
}

.qr-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.85);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.qr-content {
  width: 80%;
  background: #14142d;
  border: 1rpx solid rgba(201, 160, 80, 0.3);
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  text-align: center;
}

.qr-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #e0e0f0;
}

.qr-desc {
  font-size: 26rpx;
  color: #8888a0;
  margin-top: 8rpx;
  margin-bottom: 32rpx;
}

.qr-image-wrapper {
  display: flex;
  justify-content: center;
  margin-bottom: 24rpx;
}

.qr-image {
  width: 360rpx;
  height: 360rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.qr-code-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #c9a050;
  letter-spacing: 8rpx;
  margin-bottom: 16rpx;
}

.qr-tips {
  font-size: 24rpx;
  color: #8888a0;
  margin-bottom: 32rpx;
}

.close-btn {
  background: linear-gradient(135deg, #c9a050 0%, #e0b868 100%);
  color: #1a1a2e;
  border-radius: 50rpx;
  padding: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
}
