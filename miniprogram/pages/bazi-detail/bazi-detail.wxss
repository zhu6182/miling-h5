.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #0a0a1a 0%, #0f0f2a 50%, #0a0a1a 100%);
  padding: 20rpx 24rpx 60rpx;
  box-sizing: border-box;
}

.loading {
  text-align: center;
  padding: 200rpx 0;
  color: #8888a0;
}

.header-info {
  text-align: center;
  padding: 20rpx 0 30rpx;
}

.header-title-row {
  margin-bottom: 10rpx;
}

.header-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #e0e0f0;
}

.header-meta {
  font-size: 26rpx;
  color: #a0a0c0;
  margin-bottom: 6rpx;
}

.header-lunar {
  font-size: 22rpx;
  color: #8888a0;
}

.header-actions {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
  flex-wrap: wrap;
}

.switch-type-btn {
  display: inline-block;
  font-size: 22rpx;
  color: #c9a050;
  background: rgba(201, 160, 80, 0.1);
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
}

.match-btn {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: #c9a050;
  background: rgba(201, 160, 80, 0.1);
  border: 1rpx solid rgba(201, 160, 80, 0.4);
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
}

.match-btn.kline-btn {
  color: #80d0f0;
  background: rgba(80, 208, 240, 0.1);
  border-color: rgba(80, 208, 240, 0.4);
}

.match-icon {
  font-size: 24rpx;
}

.bazi-card {
  background: linear-gradient(135deg, rgba(30, 30, 60, 0.9) 0%, rgba(20, 20, 45, 0.95) 100%);
  border: 1rpx solid rgba(201, 160, 80, 0.3);
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  backdrop-filter: blur(10px);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3);
}

.pillars-header {
  display: flex;
  background: linear-gradient(90deg, rgba(201, 160, 80, 0.15) 0%, rgba(201, 160, 80, 0.05) 50%, rgba(201, 160, 80, 0.15) 100%);
  border-bottom: 1rpx solid rgba(201, 160, 80, 0.2);
}

.pillar-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 8rpx;
}

.pillar-col.pillar-day {
  background: rgba(201, 160, 80, 0.08);
  position: relative;
}

.pillar-label {
  font-size: 24rpx;
  color: #c9a050;
  font-weight: 600;
}

.pillars-gan {
  display: flex;
  padding: 20rpx 0 10rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.04);
}

.pillars-gan .pillar-col {
  padding: 10rpx 8rpx;
}

.pillars-gan .pillar-col.pillar-day {
  background: rgba(201, 160, 80, 0.06);
}

.shi-shen-gan {
  font-size: 22rpx;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.shi-shen-gan.type-cai { color: #f0c060; }
.shi-shen-gan.type-guan { color: #f08080; }
.shi-shen-gan.type-yin { color: #80d0f0; }
.shi-shen-gan.type-bi { color: #a0e0a0; }
.shi-shen-gan.type-shi { color: #e0a0f0; }
.shi-shen-gan.type-day { color: #ffd700; font-weight: 700; }

.gan-char {
  font-size: 56rpx;
  font-weight: 600;
  line-height: 1.1;
}

.gan-char.day-master {
  font-size: 60rpx;
  font-weight: 700;
  text-shadow: 0 0 20rpx rgba(255, 215, 0, 0.3);
}

.pillars-zhi {
  display: flex;
  padding: 10rpx 0 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.04);
}

.pillars-zhi .pillar-col {
  padding: 10rpx 8rpx;
}

.pillars-zhi .pillar-col.pillar-day {
  background: rgba(201, 160, 80, 0.06);
}

.zhi-char {
  font-size: 56rpx;
  font-weight: 600;
  line-height: 1.1;
}

.detail-table {
  width: 100%;
}

.table-row {
  display: flex;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.04);
}

.table-row:last-child {
  border-bottom: none;
}

.row-label {
  flex: 0 0 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(201, 160, 80, 0.08);
  padding: 16rpx 8rpx;
  border-right: 1rpx solid rgba(201, 160, 80, 0.15);
}

.row-label text {
  font-size: 22rpx;
  color: #c9a050;
  font-weight: 500;
}

.row-cells {
  flex: 1;
  display: flex;
}

.cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 8rpx;
  gap: 6rpx;
  min-height: 60rpx;
}

.cell.cell-day {
  background: rgba(201, 160, 80, 0.04);
}

.multi-item {
  display: flex;
  align-items: center;
  justify-content: center;
}

.hidden-gan {
  font-weight: 500;
}

.hidden-gan.main {
  font-size: 26rpx;
}

.hidden-gan.sub {
  font-size: 20rpx;
  opacity: 0.85;
}

.zhi-shishen {
  font-weight: 500;
}

.zhi-shishen.main {
  font-size: 22rpx;
}

.zhi-shishen.sub {
  font-size: 18rpx;
  opacity: 0.85;
}

.zhi-shishen.type-cai { color: #f0c060; }
.zhi-shishen.type-guan { color: #f08080; }
.zhi-shishen.type-yin { color: #80d0f0; }
.zhi-shishen.type-bi { color: #a0e0a0; }
.zhi-shishen.type-shi { color: #e0a0f0; }

.single-text {
  font-size: 22rpx;
  color: #b0b0c8;
}

.wuxing-card {
  background: linear-gradient(135deg, rgba(30, 30, 60, 0.8) 0%, rgba(20, 20, 45, 0.9) 100%);
  border: 1rpx solid rgba(201, 160, 80, 0.25);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
  backdrop-filter: blur(10px);
}

.wuxing-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.wuxing-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #e0e0f0;
}

.wuxing-card-sub {
  font-size: 22rpx;
  color: #8888a0;
}

.wuxing-bars {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.wx-bar-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.wx-bar-label {
  width: 48rpx;
  text-align: center;
}

.wx-bar-name {
  font-size: 28rpx;
  font-weight: 600;
}

.wx-jin { color: #f0d080; }
.wx-mu { color: #80e0a0; }
.wx-shui { color: #80b0f0; }
.wx-huo { color: #f08080; }
.wx-tu { color: #d0a070; }

.wx-bar-track {
  flex: 1;
  height: 24rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
}

.wx-bar-fill {
  height: 100%;
  border-radius: 12rpx;
  position: relative;
  transition: width 0.6s ease-out;
}

.wx-bar-glow {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(90deg, rgba(255,255,255,0.3) 0%, rgba(255,255,255,0) 60%);
  border-radius: 12rpx;
}

.fill-jin { background: linear-gradient(90deg, #c9a040, #f0d080); }
.fill-mu { background: linear-gradient(90deg, #40a060, #80e0a0); }
.fill-shui { background: linear-gradient(90deg, #4070c0, #80b0f0); }
.fill-huo { background: linear-gradient(90deg, #c04040, #f08080); }
.fill-tu { background: linear-gradient(90deg, #a07040, #d0a070); }

.wx-bar-count {
  width: 64rpx;
  text-align: right;
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  gap: 2rpx;
}

.wx-count-num {
  font-size: 28rpx;
  font-weight: 600;
  color: #e0e0f0;
}

.wx-count-unit {
  font-size: 18rpx;
  color: #8888a0;
}

.info-section {
  background: linear-gradient(135deg, rgba(30, 30, 60, 0.8) 0%, rgba(20, 20, 45, 0.9) 100%);
  border: 1rpx solid rgba(201, 160, 80, 0.25);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  backdrop-filter: blur(10px);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #e0e0f0;
}

.section-sub {
  font-size: 22rpx;
  color: #8888a0;
}

.shensha-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.shensha-tag {
  font-size: 22rpx;
  color: #c9a050;
  background: rgba(201, 160, 80, 0.12);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(201, 160, 80, 0.2);
}

.dayun-scroll {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
  padding-bottom: 8rpx;
}

.dayun-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  flex: 0 0 auto;
  padding: 16rpx 20rpx;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 12rpx;
  border: 1rpx solid rgba(201, 160, 80, 0.1);
}

.dayun-age {
  font-size: 20rpx;
  color: #8888a0;
}

.dayun-ganzhi {
  font-size: 28rpx;
  color: #e0e0f0;
  font-weight: 600;
}

.reading-section {
  background: linear-gradient(135deg, rgba(30, 30, 60, 0.8) 0%, rgba(20, 20, 45, 0.9) 100%);
  border: 1rpx solid rgba(201, 160, 80, 0.25);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  backdrop-filter: blur(10px);
}

.generate-btn {
  background: linear-gradient(135deg, #c9a050, #a07830);
  color: #fff;
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
}

.generate-btn.disabled {
  opacity: 0.6;
}

.reading-content {
  font-size: 28rpx;
  color: #c0c0d8;
  line-height: 1.8;
  margin-top: 20rpx;
}

.no-reading {
  text-align: center;
  padding: 60rpx 0;
}

.no-reading-icon {
  font-size: 60rpx;
  display: block;
  margin-bottom: 16rpx;
}

.no-reading-text {
  font-size: 26rpx;
  color: #8888a0;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  width: 100%;
  max-height: 70vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #0f0f1f 100%);
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 1rpx solid rgba(201, 160, 80, 0.15);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #e0e0f0;
}

.modal-close {
  font-size: 48rpx;
  color: #8888a0;
  line-height: 1;
}

.modal-loading {
  text-align: center;
  padding: 80rpx 0;
  color: #8888a0;
  font-size: 28rpx;
}

.modal-empty {
  text-align: center;
  padding: 80rpx 0;
  color: #8888a0;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
}

.chart-list {
  flex: 1;
  max-height: 60vh;
  padding: 16rpx 24rpx 40rpx;
}

.chart-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(201, 160, 80, 0.15);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.chart-item-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.chart-item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #e0e0f0;
}

.chart-item-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.chart-item-gender {
  font-size: 22rpx;
  color: #c9a050;
  background: rgba(201, 160, 80, 0.12);
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}

.chart-item-date {
  font-size: 22rpx;
  color: #8888a0;
}

.chart-item-bazi {
  font-size: 22rpx;
  color: #c9a050;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.chart-item-arrow {
  font-size: 28rpx;
  color: #c9a050;
  margin-left: 16rpx;
}

.add-friend-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx;
  margin-top: 16rpx;
  background: rgba(128, 208, 240, 0.1);
  border: 1rpx dashed rgba(128, 208, 240, 0.4);
  border-radius: 16rpx;
  color: #80d0f0;
  font-size: 26rpx;
}

.add-icon {
  font-size: 32rpx;
  font-weight: 600;
}

.friend-form {
  padding: 24rpx;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 24rpx;
  color: #a0a0c0;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #e0e0f0;
  box-sizing: border-box;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #e0e0f0;
}

.picker-arrow {
  font-size: 20rpx;
  color: #8888a0;
}

.gender-switch {
  display: flex;
  gap: 16rpx;
}

.gender-option {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #a0a0c0;
}

.gender-option.active {
  background: rgba(201, 160, 80, 0.15);
  border-color: rgba(201, 160, 80, 0.4);
  color: #c9a050;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #c9a050, #a07830);
  color: #fff;
  border: none;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin-top: 16rpx;
}
