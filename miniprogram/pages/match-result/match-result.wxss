.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #8888a0;
}

.match-header {
  text-align: center;
  padding: 40rpx 32rpx 32rpx;
  background: linear-gradient(180deg, rgba(30, 30, 60, 0.8) 0%, rgba(15, 15, 30, 0) 100%);
  border-radius: 0 0 40rpx 40rpx;
  margin: -32rpx -32rpx 32rpx;
}

.users-row {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 32rpx;
  margin-bottom: 32rpx;
}

.user-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: linear-gradient(135deg, #c9a050 0%, #e0b868 100%);
  color: #1a1a2e;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 50%;
}

.name {
  font-size: 28rpx;
  color: #e0e0f0;
  font-weight: 500;
}

.soul {
  font-size: 22rpx;
  color: #c9a050;
}

.connector {
  display: flex;
  align-items: center;
  justify-content: center;
}

.heart {
  font-size: 32rpx;
  color: #c9a050;
}

.overall-score {
  margin-bottom: 20rpx;
}

.score-num {
  font-size: 72rpx;
  font-weight: 700;
  letter-spacing: -4rpx;
}

.score-label {
  font-size: 28rpx;
  color: #8888a0;
  margin-left: 8rpx;
}

.score-bar-wrapper {
  padding: 0 60rpx;
}

.score-bar {
  height: 12rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 6rpx;
  overflow: hidden;
}

.score-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 1s ease-out;
}

.tab-bar {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 8rpx;
  font-size: 26rpx;
  color: #8888a0;
  background: rgba(20, 20, 45, 0.6);
  border: 1rpx solid rgba(201, 160, 80, 0.15);
  border-radius: 16rpx;
  transition: all 0.3s;
}

.tab.active {
  color: #c9a050;
  background: rgba(201, 160, 80, 0.15);
  border-color: rgba(201, 160, 80, 0.4);
}

.dim-content {
  margin-bottom: 120rpx;
}

.dim-card {
  background: rgba(20, 20, 45, 0.8);
  border: 1rpx solid rgba(201, 160, 80, 0.2);
  border-radius: 20rpx;
  padding: 32rpx;
}

.dim-score-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.dim-icon {
  font-size: 36rpx;
}

.dim-name {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #e0e0f0;
}

.dim-score {
  font-size: 40rpx;
  font-weight: 700;
}

.tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.tag {
  font-size: 22rpx;
  color: #c9a050;
  background: rgba(201, 160, 80, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.dim-summary {
  font-size: 26rpx;
  color: #c0c0d8;
  line-height: 1.7;
  margin-bottom: 20rpx;
}

.dim-advice {
  background: rgba(80, 180, 180, 0.08);
  border: 1rpx solid rgba(80, 180, 180, 0.15);
  border-radius: 12rpx;
  padding: 20rpx;
}

.advice-label {
  display: block;
  font-size: 24rpx;
  color: #50b4b4;
  margin-bottom: 8rpx;
}

.advice-text {
  font-size: 26rpx;
  color: #c0c0d8;
  line-height: 1.6;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(15, 15, 30, 0.95);
  backdrop-filter: blur(10px);
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.action-btn.primary {
  background: linear-gradient(135deg, #c9a050 0%, #e0b868 100%);
  color: #1a1a2e;
}

.action-btn.secondary {
  background: rgba(20, 20, 45, 0.8);
  border: 1rpx solid rgba(201, 160, 80, 0.3);
  color: #c9a050;
}

/* 锁定状态样式 */
.locked-view {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.locked-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.locked-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #e0e0f0;
  margin-bottom: 16rpx;
}

.locked-desc {
  font-size: 26rpx;
  color: #8888a0;
  margin-bottom: 60rpx;
  text-align: center;
}

.unlock-btn {
  background: linear-gradient(135deg, #c9a050 0%, #e0b868 100%);
  color: #1a1a2e;
  font-size: 30rpx;
  font-weight: 600;
  padding: 28rpx 60rpx;
  border-radius: 50rpx;
}
