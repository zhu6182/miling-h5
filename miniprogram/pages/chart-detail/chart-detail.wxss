.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #8888a0;
}

.chart-header-info {
  text-align: center;
  padding: 20rpx 0 30rpx;
}

.chart-title-row {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 8rpx;
}

.chart-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #e0e0f0;
}

.chart-elements {
  font-size: 22rpx;
  color: #c9a050;
  background: rgba(201, 160, 80, 0.15);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.chart-meta {
  font-size: 24rpx;
  color: #8888a0;
}

.header-actions {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
  flex-wrap: wrap;
}

.switch-type-btn {
  display: inline-block;
  font-size: 22rpx;
  color: #c9a050;
  background: rgba(201, 160, 80, 0.1);
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
}

.match-btn {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: #c9a050;
  background: rgba(201, 160, 80, 0.1);
  border: 1rpx solid rgba(201, 160, 80, 0.4);
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
}

.match-icon {
  font-size: 24rpx;
}

.four-hua-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.four-hua-label {
  font-size: 24rpx;
  color: #8888a0;
}

.four-hua-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.hua-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}

.hua-lu { color: #50c878; background: rgba(80, 200, 120, 0.15); }
.hua-quan { color: #c9a050; background: rgba(201, 160, 80, 0.15); }
.hua-ke { color: #6090c8; background: rgba(96, 144, 200, 0.15); }
.hua-ji { color: #e06060; background: rgba(224, 96, 96, 0.15); }

.chart-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8rpx;
  margin-bottom: 40rpx;
  aspect-ratio: 1;
}

.grid-cell {
  position: relative;
}

.center-area {
  background: rgba(201, 160, 80, 0.1);
  border: 1rpx solid rgba(201, 160, 80, 0.3);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 100%;
  grid-column: 2 / 4;
  grid-row: 2 / 4;
}

.center-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #c9a050;
  letter-spacing: 8rpx;
}

.center-sub {
  font-size: 22rpx;
  color: #8888a0;
  margin-top: 8rpx;
}

.palace-cell {
  background: rgba(20, 20, 45, 0.6);
  border: 1rpx solid rgba(201, 160, 80, 0.2);
  border-radius: 12rpx;
  padding: 12rpx 8rpx;
  min-height: 120rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.palace-cell.active {
  background: rgba(224, 96, 96, 0.1);
  border-color: rgba(224, 96, 96, 0.5);
}

.palace-cell.body-palace {
  background: rgba(96, 144, 200, 0.1);
  border-color: rgba(96, 144, 200, 0.5);
}

.palace-name {
  font-size: 18rpx;
  color: #8888a0;
}

.palace-branch {
  font-size: 20rpx;
  color: #c9a050;
  font-weight: 500;
}

.palace-stars {
  display: flex;
  flex-wrap: wrap;
  gap: 2rpx 6rpx;
}

.star {
  font-size: 18rpx;
  color: #c0c0d8;
}

.star.main {
  color: #e0e0f0;
  font-weight: 500;
}

.star.empty {
  color: #666680;
  font-style: italic;
}

.empty-cell {
  background: transparent;
  border: none;
}

.reading-section {
  margin-top: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #e0e0f0;
}

.generate-btn {
  font-size: 24rpx;
  color: #c9a050;
  background: rgba(201, 160, 80, 0.15);
  border: 1rpx solid rgba(201, 160, 80, 0.4);
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
}

.generate-btn.disabled {
  opacity: 0.6;
}

.reading-cards {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.reading-card {
  background: rgba(20, 20, 45, 0.8);
  border: 1rpx solid rgba(201, 160, 80, 0.2);
  border-radius: 16rpx;
  padding: 28rpx;
}

.reading-card.full {
  grid-column: 1 / -1;
}

.reading-card.highlight {
  border-color: rgba(224, 96, 96, 0.5);
  background: linear-gradient(135deg, rgba(224, 96, 96, 0.1) 0%, rgba(20, 20, 45, 0.8) 100%);
}

.reading-card.teal-highlight {
  border-color: rgba(80, 180, 180, 0.5);
  background: linear-gradient(135deg, rgba(80, 180, 180, 0.1) 0%, rgba(20, 20, 45, 0.8) 100%);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #e0e0f0;
}

.card-badge {
  font-size: 22rpx;
  color: #c9a050;
}

.card-body {
  font-size: 26rpx;
  line-height: 1.8;
  color: #c0c0d8;
}

.card-body :deep(strong) { color: #e0e0f0; font-weight: 600; }
.card-body :deep(em) { color: #c9a050; font-style: normal; }

.prob-section {
  margin-top: 20rpx;
}

.prob-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.prob-label {
  font-size: 22rpx;
  color: #8888a0;
  width: 140rpx;
}

.prob-track {
  flex: 1;
  height: 12rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 6rpx;
  overflow: hidden;
}

.prob-fill {
  height: 100%;
  background: linear-gradient(90deg, #c9a050 0%, #e0b868 100%);
  border-radius: 6rpx;
  transition: width 0.5s;
}

.prob-pct {
  font-size: 22rpx;
  color: #c9a050;
  width: 60rpx;
  text-align: right;
}

.calibration-section {
  margin-top: 40rpx;
  padding: 28rpx;
  background: rgba(80, 180, 180, 0.08);
  border: 1rpx solid rgba(80, 180, 180, 0.2);
  border-radius: 16rpx;
}

.calibration-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #50b4b4;
  margin-bottom: 8rpx;
}

.calibration-desc {
  font-size: 24rpx;
  color: #8888a0;
  margin-bottom: 20rpx;
}

.cal-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.cal-item {
  background: rgba(20, 20, 45, 0.5);
  border-radius: 12rpx;
  padding: 20rpx;
}

.cal-question {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.cal-num {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  background: rgba(80, 180, 180, 0.2);
  color: #50b4b4;
  border-radius: 50%;
  font-size: 22rpx;
  flex-shrink: 0;
}

.cal-text {
  flex: 1;
  font-size: 26rpx;
  color: #e0e0f0;
  line-height: 1.5;
}

.cal-options {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-left: 56rpx;
}

.cal-option {
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(80, 180, 180, 0.3);
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #a0a0c0;
  transition: all 0.2s;
}

.cal-option.selected {
  background: rgba(80, 180, 180, 0.2);
  border-color: #50b4b4;
  color: #50b4b4;
}

.cal-hint {
  font-size: 22rpx;
  color: #666680;
  margin-top: 4rpx;
  margin-left: 56rpx;
  display: block;
}

.cal-submit-btn {
  margin-top: 28rpx;
  background: linear-gradient(135deg, #50b4b4 0%, #70d0d0 100%);
  color: #1a1a2e;
  text-align: center;
  padding: 24rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.no-reading {
  text-align: center;
  padding: 60rpx 0;
  color: #8888a0;
}

.no-reading-icon {
  font-size: 60rpx;
  display: block;
  margin-bottom: 16rpx;
}

.no-reading-text {
  font-size: 26rpx;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  width: 100%;
  max-height: 70vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #0f0f1f 100%);
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 1rpx solid rgba(201, 160, 80, 0.15);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #e0e0f0;
}

.modal-close {
  font-size: 48rpx;
  color: #8888a0;
  line-height: 1;
}

.modal-loading {
  text-align: center;
  padding: 80rpx 0;
  color: #8888a0;
  font-size: 28rpx;
}

.modal-empty {
  text-align: center;
  padding: 80rpx 0;
  color: #8888a0;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
}

.chart-list {
  flex: 1;
  max-height: 60vh;
  padding: 16rpx 24rpx 40rpx;
}

.chart-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(201, 160, 80, 0.15);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.chart-item-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.chart-item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #e0e0f0;
}

.chart-item-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.chart-item-gender {
  font-size: 22rpx;
  color: #c9a050;
  background: rgba(201, 160, 80, 0.12);
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}

.chart-item-date {
  font-size: 22rpx;
  color: #8888a0;
}

.chart-item-bazi {
  font-size: 22rpx;
  color: #c9a050;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.chart-item-arrow {
  font-size: 28rpx;
  color: #c9a050;
  margin-left: 16rpx;
}

.add-friend-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx;
  margin-top: 16rpx;
  background: rgba(128, 208, 240, 0.1);
  border: 1rpx dashed rgba(128, 208, 240, 0.4);
  border-radius: 16rpx;
  color: #80d0f0;
  font-size: 26rpx;
}

.add-icon {
  font-size: 32rpx;
  font-weight: 600;
}

.friend-form {
  padding: 24rpx;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 24rpx;
  color: #a0a0c0;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #e0e0f0;
  box-sizing: border-box;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #e0e0f0;
}

.picker-arrow {
  font-size: 20rpx;
  color: #8888a0;
}

.gender-switch {
  display: flex;
  gap: 16rpx;
}

.gender-option {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #a0a0c0;
}

.gender-option.active {
  background: rgba(201, 160, 80, 0.15);
  border-color: rgba(201, 160, 80, 0.4);
  color: #c9a050;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #c9a050, #a07830);
  color: #fff;
  border: none;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin-top: 16rpx;
}
