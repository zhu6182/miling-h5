<view class="container">
  <view wx:if="{{loading}}" class="loading">
    <text>加载中...</text>
  </view>

  <block wx:elif="{{chart}}">
    <view class="chart-header-info">
      <view class="chart-title-row">
        <text class="chart-name">{{chart.name}}</text>
        <text class="chart-elements">{{chart.five_elements}}</text>
      </view>
      <view class="chart-meta">
        {{chart.solar_date}} · {{chart.hour_name}} · {{chart.gender}}
      </view>
      <view class="header-actions">
        <view class="switch-type-btn" bindtap="goBaziDetail">
          查看八字排盘 →
        </view>
        <view class="match-btn share-btn" bindtap="onShareTap">
          <text class="match-icon">📤</text>
          <text>分享</text>
        </view>
        <view class="match-btn" bindtap="openMatchSelector">
          <text class="match-icon">👥</text>
          <text>找人匹配</text>
        </view>
      </view>
    </view>

    <view class="four-hua-row">
      <text class="four-hua-label">生年四化</text>
      <view class="four-hua-tags">
        <view class="hua-tag hua-lu" wx:for="{{fourHuaTags}}" wx:key="star" wx:if="{{item.mutagen === '化禄'}}">
          {{item.star}}禄
        </view>
        <view class="hua-tag hua-quan" wx:for="{{fourHuaTags}}" wx:key="star" wx:if="{{item.mutagen === '化权'}}">
          {{item.star}}权
        </view>
        <view class="hua-tag hua-ke" wx:for="{{fourHuaTags}}" wx:key="star" wx:if="{{item.mutagen === '化科'}}">
          {{item.star}}科
        </view>
        <view class="hua-tag hua-ji" wx:for="{{fourHuaTags}}" wx:key="star" wx:if="{{item.mutagen === '化忌'}}">
          {{item.star}}忌
        </view>
      </view>
    </view>

    <view class="chart-grid">
      <view class="grid-cell" wx:for="{{palaceGrid}}" wx:key="index">
        <block wx:if="{{item.isCenter}}">
          <view class="center-area">
            <view class="center-title">命盘</view>
            <view class="center-sub">{{soulBranch}}宫命</view>
          </view>
        </block>
        <block wx:elif="{{item.palace}}">
          <view class="palace-cell {{item.palace.tags[0] === '命宫' ? 'active' : ''}} {{item.palace.tags[0] === '身宫' ? 'body-palace' : ''}}">
            <view class="palace-name">{{item.palace.name}}</view>
            <view class="palace-branch">{{item.palace.earthly_branch}}</view>
            <view class="palace-stars">
              <text class="star main" wx:for="{{item.palace.major_stars}}" wx:for-item="star" wx:key="*this">{{star}}</text>
              <text class="star minor" wx:for="{{item.palace.minor_stars}}" wx:for-item="star" wx:key="*this">{{star}}</text>
              <text wx:if="{{!item.palace.major_stars.length}}" class="star empty">空宫</text>
            </view>
          </view>
        </block>
        <block wx:else>
          <view class="palace-cell empty-cell"></view>
        </block>
      </view>
    </view>

    <view class="reading-section">
      <view class="section-header">
        <text class="section-title">AI 解读</text>
        <view class="generate-btn {{generating ? 'disabled' : ''}}" bindtap="generateReading">
          <text wx:if="{{!reading && !generating && !readingLocked}}">生成解读</text>
          <text wx:elif="{{readingLocked && !reading}}">看广告解锁</text>
          <text wx:elif="{{generating}}">生成中...</text>
          <text wx:else>重新解读</text>
        </view>
      </view>

      <block wx:if="{{reading}}">
        <view class="reading-cards">
          <view class="reading-card {{item.full ? 'full' : ''}} {{item.highlight ? 'highlight' : ''}} {{item.teal ? 'teal-highlight' : ''}}"
                wx:for="{{reading.cards}}" wx:key="title">
            <view class="card-header">
              <text class="card-title">{{item.title}}</text>
              <text class="card-badge" wx:if="{{item.badge}}">{{item.badge}}</text>
            </view>
            <view class="card-body">
              <rich-text nodes="{{item.body}}"></rich-text>
            </view>
            <view class="prob-section" wx:if="{{item.probabilities}}">
              <view class="prob-item" wx:for="{{item.probabilities}}" wx:for-item="pb" wx:key="label">
                <text class="prob-label">{{pb.label}}</text>
                <view class="prob-track">
                  <view class="prob-fill" style="width: {{pb.pct}}%"></view>
                </view>
                <text class="prob-pct">{{pb.pct}}%</text>
              </view>
            </view>
          </view>
        </view>

        <view class="calibration-section" wx:if="{{reading.calibration_questions}}">
          <view class="calibration-title">校准问答</view>
          <view class="calibration-desc">回答以下问题，让解读更精准（65% → 85%+）</view>
          <view class="cal-list">
            <view class="cal-item" wx:for="{{reading.calibration_questions}}" wx:key="text" wx:for-index="qIndex">
              <view class="cal-question">
                <text class="cal-num">{{qIndex + 1}}</text>
                <text class="cal-text">{{item.text}}</text>
              </view>
              <view class="cal-options" wx:if="{{item.options}}">
                <view class="cal-option {{calAnswers[qIndex] === opt ? 'selected' : ''}}"
                      wx:for="{{item.options}}" wx:for-item="opt" wx:key="*this"
                      bindtap="selectCalAnswer" data-qindex="{{qIndex}}" data-answer="{{opt}}">
                  {{opt}}
                </view>
              </view>
              <view class="cal-hint" wx:if="{{item.hint && !item.options}}">{{item.hint}}</view>
            </view>
          </view>
          <view class="cal-submit-btn" bindtap="submitCalibration">完成校准</view>
        </view>
      </block>

      <view class="no-reading" wx:else>
        <text class="no-reading-icon">✨</text>
        <text class="no-reading-text">点击上方按钮，生成 AI 解读</text>
      </view>
    </view>
  </block>

  <view wx:if="{{showMatchModal}}" class="modal-mask" bindtap="closeMatchSelector">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">选择要匹配的命盘</text>
        <view class="modal-close" bindtap="closeMatchSelector">×</view>
      </view>
      <view wx:if="{{chartsLoading}}" class="modal-loading">
        <text>加载中...</text>
      </view>
      <view wx:elif="{{filteredCharts.length === 0}}" class="modal-empty">
        <text class="empty-icon">📋</text>
        <text class="empty-text">暂无其他命盘可匹配</text>
        <view class="add-friend-btn" bindtap="openAddFriendChart">
          <text class="add-icon">+</text>
          <text>添加好友命盘</text>
        </view>
      </view>
      <scroll-view wx:else class="chart-list" scroll-y>
        <view class="chart-item" wx:for="{{filteredCharts}}" wx:key="id" bindtap="selectChartForMatch" data-id="{{item.id}}">
          <view class="chart-item-left">
            <text class="chart-item-name">{{item.remark || item.name}}</text>
            <view class="chart-item-meta">
              <text class="chart-item-gender">{{item.gender}}</text>
              <text wx:if="{{item.bazi_display}}" class="chart-item-bazi">{{item.bazi_display}}</text>
              <text wx:else class="chart-item-date">{{item.solar_date}} {{item.hour_name}}</text>
            </view>
          </view>
          <text class="chart-item-arrow">→</text>
        </view>
      </scroll-view>
      <view class="add-friend-btn" bindtap="openAddFriendChart">
        <text class="add-icon">+</text>
        <text>添加好友命盘</text>
      </view>
    </view>
  </view>

  <view wx:if="{{showAddFriendModal}}" class="modal-mask" bindtap="closeAddFriendChart">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">添加好友命盘</text>
        <view class="modal-close" bindtap="closeAddFriendChart">×</view>
      </view>
      <view class="friend-form">
        <view class="form-item">
          <text class="form-label">备注名</text>
          <input class="form-input" placeholder="如：张三" value="{{friendName}}" bindinput="bindFriendNameInput" />
        </view>
        <view class="form-item">
          <text class="form-label">性别</text>
          <view class="gender-switch">
            <view class="gender-option {{friendGender === 'male' ? 'active' : ''}}" bindtap="switchFriendGender" data-gender="male">男</view>
            <view class="gender-option {{friendGender === 'female' ? 'active' : ''}}" bindtap="switchFriendGender" data-gender="female">女</view>
          </view>
        </view>
        <view class="form-item">
          <text class="form-label">出生日期</text>
          <picker mode="date" value="{{friendDate}}" bindchange="bindFriendDateInput">
            <view class="form-picker">
              {{friendDate || '请选择日期'}}
              <text class="picker-arrow">▼</text>
            </view>
          </picker>
        </view>
        <view class="form-item">
          <text class="form-label">出生时辰</text>
          <picker mode="selector" range="{{['子时','丑时','寅时','卯时','辰时','巳时','午时','未时','申时','酉时','戌时','亥时']}}" value="6" bindchange="bindFriendHourInput">
            <view class="form-picker">
              {{friendHour || '请选择时辰'}}
              <text class="picker-arrow">▼</text>
            </view>
          </picker>
        </view>
        <button class="submit-btn" bindtap="saveFriendChart">保存并匹配</button>
      </view>
    </view>
  </view>
</view>
