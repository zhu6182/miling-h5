<view class="container">
  <block wx:if="{{!userInfo}}">
    <view class="profile-header no-login">
      <view class="avatar-placeholder">👤</view>
      <view class="nickname">未登录</view>
      <view class="btn-primary" bindtap="showLoginModal" style="margin-top:24rpx;">登录 / 注册</view>
    </view>
  </block>

  <block wx:else>
    <view class="profile-header">
      <view class="avatar">{{userInfo.nickname[0]}}</view>
      <view class="nickname">{{userInfo.nickname}}</view>
      <view class="phone" wx:if="{{userInfo.phone}}">{{userInfo.phone}}</view>
      <view class="phone" wx:else>微信用户</view>
    </view>

    <view class="menu-section">
      <view class="menu-item" bindtap="goBirthInput">
        <text class="menu-icon">✨</text>
        <text class="menu-text">新建星盘</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="toggleFriends">
        <text class="menu-icon">👥</text>
        <text class="menu-text">我的好友</text>
        <text class="menu-count" wx:if="{{friends.length > 0}}">{{friends.length}}</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="friends-section" wx:if="{{showFriends && friends.length > 0}}">
      <view class="friends-list">
        <view class="friend-item" wx:for="{{friends}}" wx:key="user_id">
          <view class="friend-avatar">{{item.nickname[0]}}</view>
          <view class="friend-info">
          <text class="friend-name">{{item.nickname}}</text>
          <text class="friend-soul" wx:if="{{item.soul_palace}}">{{item.soul_palace}}守护星</text>
        </view>
          <view class="friend-actions">
            <text class="friend-btn match" bindtap="goMatchWithFriend" data-id="{{item.user_id}}">配对</text>
            <text class="friend-btn remove" bindtap="removeFriend" data-id="{{item.user_id}}">删除</text>
          </view>
        </view>
      </view>
    </view>

    <view class="menu-section">
      <view class="menu-title">AI 设置</view>
      <view class="ai-provider-row">
        <view class="ai-provider-btn {{aiProvider === 'mock' ? 'active' : ''}}"
              bindtap="selectAiProvider" data-provider="mock">
          内置
        </view>
        <view class="ai-provider-btn {{aiProvider === 'volcengine' ? 'active' : ''}}"
              bindtap="selectAiProvider" data-provider="volcengine">
          豆包
        </view>
        <view class="ai-provider-btn {{aiProvider === 'openai' ? 'active' : ''}}"
              bindtap="selectAiProvider" data-provider="openai">
          OpenAI
        </view>
        <view class="ai-provider-btn {{aiProvider === 'tongyi' ? 'active' : ''}}"
              bindtap="selectAiProvider" data-provider="tongyi">
          通义千问
        </view>
      </view>

      <view class="ai-settings" wx:if="{{aiProvider !== 'mock'}}">
        <view class="form-item">
          <text class="form-label">API Key</text>
          <input class="form-input" password placeholder="输入你的 API Key" value="{{aiApiKey}}" bindinput="onAiApiKeyInput" />
        </view>
        <view class="form-item">
          <text class="form-label">模型名称</text>
          <input class="form-input" placeholder="如 doubao-pro-32k" value="{{aiModel}}" bindinput="onAiModelInput" />
        </view>
        <view class="form-item">
          <text class="form-label">接口地址 (Base URL)</text>
          <input class="form-input" placeholder="如 https://ark.cn-beijing.volces.com/api/v3" value="{{aiBaseUrl}}" bindinput="onAiBaseUrlInput" />
        </view>
        <view class="save-btn {{loading ? 'disabled' : ''}}" bindtap="saveAiSettings">
          {{loading ? '保存中...' : '保存 AI 设置'}}
        </view>
      </view>
    </view>

    <view class="menu-section">
      <view class="menu-item" bindtap="toggleServerConfig">
        <text class="menu-icon">⚙️</text>
        <text class="menu-text">服务地址设置</text>
        <text class="menu-arrow">{{showServerConfig ? '−' : '+'}}</text>
      </view>
      <view class="server-config" wx:if="{{showServerConfig}}">
        <view class="form-item">
          <text class="form-label">后端服务地址</text>
          <input class="form-input" placeholder="http://192.168.1.2:8000/api/v1" value="{{serverBaseUrl}}" bindinput="onServerBaseUrlInput" />
        </view>
        <view class="server-config-actions">
          <view class="save-btn" bindtap="saveServerBaseUrl">保存</view>
          <view class="reset-btn" bindtap="resetServerBaseUrl">恢复默认</view>
        </view>
        <view class="config-tip">真机调试时请确保手机和电脑在同一WiFi下</view>
      </view>
    </view>

    <view class="menu-section">
      <view class="menu-item">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">关于「星运日记」</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="logout-btn" bindtap="logout">退出登录</view>
  </block>

  <view class="login-modal" wx:if="{{showLogin}}" catchtap="closeLoginModal">
    <view class="modal-content" catchtap="">
      <view class="modal-title">微信一键登录</view>
      <view class="modal-subtitle">使用微信账号快速登录星运日记</view>

      <view class="wechat-login-btn" bindtap="wechatLogin">
        <text class="wechat-icon">💬</text>
        <text>{{loading ? '登录中...' : '微信一键登录'}}</text>
      </view>

      <view class="login-tip">登录即表示同意《用户协议》和《隐私政策》</view>
      <view class="close-modal" bindtap="closeLoginModal">✕</view>
    </view>
  </view>
</view>
