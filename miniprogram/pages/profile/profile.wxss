.profile-header {
  text-align: center;
  padding: 60rpx 0 40rpx;
}

.profile-header.no-login {
  padding: 80rpx 0 60rpx;
}

.avatar-placeholder {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  line-height: 120rpx;
  text-align: center;
  background: linear-gradient(135deg, #c9a050 0%, #e0b868 100%);
  color: #1a1a2e;
  font-size: 48rpx;
  font-weight: 600;
  border-radius: 50%;
  margin: 0 auto 20rpx;
}

.nickname {
  font-size: 34rpx;
  font-weight: 600;
  color: #e0e0f0;
}

.phone {
  font-size: 26rpx;
  color: #8888a0;
  margin-top: 8rpx;
}

.menu-section {
  background: rgba(20, 20, 45, 0.8);
  border: 1rpx solid rgba(201, 160, 80, 0.2);
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.menu-title {
  padding: 24rpx 28rpx 12rpx;
  font-size: 24rpx;
  color: #8888a0;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  border-bottom: 1rpx solid rgba(201, 160, 80, 0.1);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #e0e0f0;
}

.menu-arrow {
  font-size: 32rpx;
  color: #666680;
}

.ai-provider-row {
  display: flex;
  gap: 16rpx;
  padding: 0 28rpx 28rpx;
}

.ai-provider-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 8rpx;
  border: 1rpx solid rgba(201, 160, 80, 0.3);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #8888a0;
}

.ai-provider-btn.active {
  background: rgba(201, 160, 80, 0.15);
  border-color: #c9a050;
  color: #c9a050;
}

.menu-count {
  font-size: 22rpx;
  color: #c9a050;
  background: rgba(201, 160, 80, 0.15);
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
  margin-right: 8rpx;
}

.friends-section {
  margin-bottom: 24rpx;
}

.friends-list {
  background: rgba(20, 20, 45, 0.8);
  border: 1rpx solid rgba(201, 160, 80, 0.2);
  border-radius: 20rpx;
  overflow: hidden;
}

.friend-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid rgba(201, 160, 80, 0.1);
}

.friend-item:last-child {
  border-bottom: none;
}

.friend-avatar {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  background: linear-gradient(135deg, #c9a050 0%, #e0b868 100%);
  color: #1a1a2e;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 50%;
  margin-right: 20rpx;
}

.friend-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.friend-name {
  font-size: 28rpx;
  color: #e0e0f0;
  font-weight: 500;
}

.friend-soul {
  font-size: 22rpx;
  color: #c9a050;
}

.friend-actions {
  display: flex;
  gap: 16rpx;
}

.friend-btn {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
}

.friend-btn.match {
  color: #c9a050;
  background: rgba(201, 160, 80, 0.15);
  border: 1rpx solid rgba(201, 160, 80, 0.3);
}

.friend-btn.remove {
  color: #e06060;
  background: rgba(224, 96, 96, 0.1);
  border: 1rpx solid rgba(224, 96, 96, 0.2);
}

.save-btn {
  background: linear-gradient(135deg, #c9a050 0%, #e0b868 100%);
  color: #1a1a2e;
  border-radius: 50rpx;
  padding: 20rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  margin-top: 16rpx;
}

.save-btn.disabled {
  opacity: 0.6;
}

.server-config {
  padding: 0 24rpx 24rpx;
  background: rgba(20, 20, 45, 0.4);
  border-radius: 0 0 16rpx 16rpx;
  margin-top: -16rpx;
  padding-top: 16rpx;
}

.server-config-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.server-config-actions .save-btn {
  flex: 1;
  margin-top: 0;
}

.reset-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  color: #8888a0;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.config-tip {
  font-size: 22rpx;
  color: #666680;
  text-align: center;
  margin-top: 16rpx;
}

.logout-btn {
  text-align: center;
  padding: 28rpx;
  color: #e06060;
  font-size: 28rpx;
  margin-top: 20rpx;
}

.login-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  width: 80%;
  background: #14142d;
  border: 1rpx solid rgba(201, 160, 80, 0.3);
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  position: relative;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #e0e0f0;
  text-align: center;
}

.modal-subtitle {
  font-size: 26rpx;
  color: #8888a0;
  text-align: center;
  margin-top: 8rpx;
  margin-bottom: 36rpx;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 26rpx;
  color: #c9a050;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 24rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(201, 160, 80, 0.2);
  border-radius: 12rpx;
  color: #e0e0f0;
  font-size: 28rpx;
  box-sizing: border-box;
}

.modal-btn {
  margin-top: 16rpx;
}

.switch-mode {
  text-align: center;
  font-size: 26rpx;
  color: #8888a0;
  margin-top: 28rpx;
}

.switch-link {
  color: #c9a050;
  margin-left: 8rpx;
}

.close-modal {
  position: absolute;
  top: 24rpx;
  right: 28rpx;
  font-size: 32rpx;
  color: #666680;
}

.wechat-login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: #07c160;
  color: white;
  border-radius: 50rpx;
  padding: 28rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin-top: 20rpx;
}

.wechat-icon {
  font-size: 36rpx;
}

.login-tip {
  text-align: center;
  font-size: 22rpx;
  color: #666680;
  margin-top: 24rpx;
}
