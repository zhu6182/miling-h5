.form-card {
  background: rgba(20, 20, 45, 0.8);
  border: 1rpx solid rgba(201, 160, 80, 0.2);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  margin-top: 32rpx;
  backdrop-filter: blur(10px);
}

.form-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #e0e0f0;
  text-align: center;
}

.form-desc {
  font-size: 26rpx;
  color: #8888a0;
  text-align: center;
  margin-top: 12rpx;
  margin-bottom: 40rpx;
}

.form-section {
  margin-bottom: 36rpx;
}

.section-label {
  font-size: 28rpx;
  color: #c9a050;
  margin-bottom: 20rpx;
  font-weight: 500;
}

.type-switch {
  display: flex;
  gap: 20rpx;
}

.type-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border: 1rpx solid rgba(201, 160, 80, 0.3);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #8888a0;
  transition: all 0.3s;
}

.type-btn.active {
  background: rgba(201, 160, 80, 0.15);
  border-color: #c9a050;
  color: #c9a050;
}

.picker-input {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(201, 160, 80, 0.2);
  border-radius: 16rpx;
}

.picker-text {
  font-size: 28rpx;
  color: #e0e0f0;
}

.picker-icon {
  font-size: 32rpx;
}

.remark-input-wrap {
  margin-top: 20rpx;
}

.remark-input {
  width: 100%;
  box-sizing: border-box;
  color: #e0e0f0;
  font-size: 28rpx;
}

.picker-placeholder {
  color: #666680;
  font-size: 28rpx;
}

.hour-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.hour-item {
  text-align: center;
  padding: 20rpx 12rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(201, 160, 80, 0.2);
  border-radius: 12rpx;
}

.hour-item.hour-selected {
  background: rgba(201, 160, 80, 0.15);
  border-color: #c9a050;
}

.hour-name {
  font-size: 26rpx;
  color: #e0e0f0;
  margin-bottom: 4rpx;
}

.hour-time {
  font-size: 20rpx;
  color: #8888a0;
}

.gender-switch {
  display: flex;
  gap: 24rpx;
}

.gender-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 32rpx;
  border: 1rpx solid rgba(201, 160, 80, 0.3);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #8888a0;
}

.gender-btn.active {
  background: rgba(201, 160, 80, 0.15);
  border-color: #c9a050;
  color: #c9a050;
}

.gender-icon {
  font-size: 40rpx;
}

.submit-btn {
  width: 100%;
  background: linear-gradient(135deg, #c9a050 0%, #e0b868 100%);
  color: #1a1a2e;
  border-radius: 50rpx;
  padding: 28rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 40rpx;
}

.submit-btn.disabled {
  opacity: 0.6;
}

.tip {
  text-align: center;
  font-size: 22rpx;
  color: #666680;
  margin-top: 24rpx;
}
