.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #0a0a1a 0%, #0f0f2a 50%, #0a0a1a 100%);
  padding: 20rpx 24rpx 60rpx;
  box-sizing: border-box;
}

/* 加载状态 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.6; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.1); }
}

.loading-text {
  font-size: 32rpx;
  color: #e0e0f0;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.loading-sub {
  font-size: 24rpx;
  color: #8888a0;
}

/* 标题区 */
.header-section {
  padding: 20rpx 0 24rpx;
}

.header-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #e0e0f0;
}

.share-btn {
  font-size: 24rpx;
  color: #c9a050;
  background: rgba(201, 160, 80, 0.1);
  border: 1rpx solid rgba(201, 160, 80, 0.4);
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  line-height: 1.5;
  /* 重置 button 默认样式 */
  margin: 0;
  display: inline-flex;
  align-items: center;
}

.share-btn::after {
  border: none;
}

.header-sub {
  font-size: 24rpx;
  color: #8888a0;
}

/* K线图卡片 */
.chart-card {
  background: linear-gradient(135deg, rgba(30, 30, 60, 0.9) 0%, rgba(20, 20, 45, 0.95) 100%);
  border: 1rpx solid rgba(201, 160, 80, 0.3);
  border-radius: 20rpx;
  padding: 24rpx 16rpx 16rpx;
  margin-bottom: 24rpx;
  backdrop-filter: blur(10px);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3);
}

.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 8rpx 16rpx;
}

.chart-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #e0e0f0;
}

.chart-legend {
  display: flex;
  gap: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.legend-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 4rpx;
}

.dot-up { background: #22c55e; }
.dot-down { background: #ef4444; }

.legend-text {
  font-size: 22rpx;
  color: #a0a0c0;
}

.kline-canvas {
  width: 100%;
  height: 400rpx;
}

.chart-tip {
  display: block;
  text-align: center;
  font-size: 20rpx;
  color: #8888a0;
  margin-top: 8rpx;
}

/* 巅峰与低谷 */
.highlight-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.highlight-card {
  flex: 1;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.highlight-peak {
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.12) 0%, rgba(20, 83, 45, 0.15) 100%);
  border: 1rpx solid rgba(34, 197, 94, 0.3);
}

.highlight-low {
  background: linear-gradient(135deg, rgba(239, 68, 68, 0.12) 0%, rgba(127, 29, 29, 0.15) 100%);
  border: 1rpx solid rgba(239, 68, 68, 0.3);
}

.highlight-label {
  font-size: 22rpx;
  color: #8888a0;
}

.highlight-year {
  font-size: 24rpx;
  color: #e0e0f0;
  font-weight: 600;
}

.highlight-score {
  font-size: 40rpx;
  font-weight: 700;
}

.highlight-peak .highlight-score { color: #22c55e; }
.highlight-low .highlight-score { color: #ef4444; }

.highlight-ganzhi {
  font-size: 22rpx;
  color: #c9a050;
}

/* 多维度分析 */
.analysis-section {
  margin-bottom: 24rpx;
}

.section-header {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #e0e0f0;
}

.analysis-card {
  background: linear-gradient(135deg, rgba(30, 30, 60, 0.8) 0%, rgba(20, 20, 45, 0.9) 100%);
  border: 1rpx solid rgba(201, 160, 80, 0.2);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  backdrop-filter: blur(10px);
}

.analysis-summary {
  border-color: rgba(201, 160, 80, 0.4);
  background: linear-gradient(135deg, rgba(40, 35, 20, 0.8) 0%, rgba(25, 22, 15, 0.9) 100%);
}

.card-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #e0e0f0;
}

.score-badge {
  font-size: 22rpx;
  font-weight: 700;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.card-body {
  font-size: 26rpx;
  color: #c0c0d8;
  line-height: 1.8;
}

/* 底部说明 */
/* 大运解读 */
.dayun-section {
  margin-bottom: 32rpx;
}

.dayun-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.dayun-card {
  border-radius: 20rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(201, 160, 80, 0.2);
  backdrop-filter: blur(10px);
}

.dayun-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.dayun-age {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.age-start {
  font-size: 36rpx;
  font-weight: 700;
  color: #e0e0f0;
}

.age-sep {
  font-size: 24rpx;
  color: #8888a0;
}

.age-end {
  font-size: 28rpx;
  font-weight: 600;
  color: #a0a0c0;
}

.dayun-score {
  font-size: 32rpx;
  font-weight: 700;
}

.dayun-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.dayun-ganzhi {
  font-size: 36rpx;
  font-weight: 700;
  color: #c9a050;
}

.dayun-trend {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(201, 160, 80, 0.15);
  color: #c9a050;
}

.dayun-shen {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.shen-tag {
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.06);
  color: #a0a0c0;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.dayun-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag-item {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  background: rgba(128, 208, 240, 0.12);
  color: #80d0f0;
  border: 1rpx solid rgba(128, 208, 240, 0.2);
}

.footer-note {
  text-align: center;
  padding: 40rpx 0 20rpx;
  font-size: 22rpx;
  color: #585870;
}

/* 年份详情弹窗 */
.detail-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-popup {
  width: 88%;
  max-width: 640rpx;
  background: linear-gradient(180deg, #1a1a2e 0%, #0f0f1f 100%);
  border: 1rpx solid rgba(201, 160, 80, 0.3);
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
  padding-bottom: 20rpx;
}

.detail-header-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.detail-year {
  font-size: 32rpx;
  font-weight: 700;
  color: #e0e0f0;
}

.detail-age {
  font-size: 24rpx;
  color: #c9a050;
}

.detail-trend {
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.trend-up {
  background: rgba(34, 197, 94, 0.15);
  color: #22c55e;
}

.trend-down {
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
}

.detail-data-row {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.detail-data-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 12rpx;
  padding: 16rpx 8rpx;
}

.data-label {
  font-size: 20rpx;
  color: #8888a0;
}

.data-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #e0e0f0;
  font-family: monospace;
}

.data-score {
  color: #c9a050;
  font-size: 32rpx;
}

.detail-reason {
  background: rgba(255, 255, 255, 0.03);
  border-radius: 12rpx;
  padding: 20rpx;
}

.reason-label {
  display: block;
  font-size: 22rpx;
  color: #c9a050;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.reason-text {
  font-size: 26rpx;
  color: #c0c0d8;
  line-height: 1.7;
}

.detail-close-btn {
  text-align: center;
  background: linear-gradient(135deg, #c9a050, #a07830);
  color: #fff;
  padding: 18rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
}
