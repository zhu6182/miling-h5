<view class="container">
  <!-- 加载/生成中 -->
  <view wx:if="{{loading || generating}}" class="loading-wrap">
    <view class="loading-icon">🔮</view>
    <text class="loading-text">{{generating ? 'AI 推演人生运势中...' : '加载中...'}}</text>
    <text class="loading-sub">正在结合八字命理与大运流年生成K线数据</text>
  </view>

  <!-- 数据展示 -->
  <block wx:elif="{{klineData}}">
    <!-- 标题区 -->
    <view class="header-section">
      <view class="header-title-row">
        <text class="header-title">📈 人生K线</text>
        <button class="share-btn" open-type="share">
          <text>📤 分享</text>
        </button>
      </view>
      <text class="header-sub">将一生运势以K线图形式可视化展现</text>
    </view>

    <!-- K线图 -->
    <view class="chart-card">
      <view class="chart-header">
        <text class="chart-title">流年大运走势图</text>
        <view class="chart-legend">
          <view class="legend-item">
            <view class="legend-dot dot-up"></view>
            <text class="legend-text">吉运</text>
          </view>
          <view class="legend-item">
            <view class="legend-dot dot-down"></view>
            <text class="legend-text">凶运</text>
          </view>
        </view>
      </view>
      <canvas 
        canvas-id="klineCanvas" 
        id="klineCanvas"
        class="kline-canvas" 
        bindtap="onChartTap"
      ></canvas>
      <text class="chart-tip">点击K线上的任意位置查看该年详情</text>
    </view>

    <!-- 巅峰与低谷 -->
    <view class="highlight-row">
      <view class="highlight-card highlight-peak">
        <text class="highlight-label">人生巅峰</text>
        <text class="highlight-year">{{peakYear.year}}年 ({{peakYear.age}}岁)</text>
        <text class="highlight-score">{{peakYear.score}}分</text>
        <text class="highlight-ganzhi">{{peakYear.ganZhi}}</text>
      </view>
      <view class="highlight-card highlight-low">
        <text class="highlight-label">人生低谷</text>
        <text class="highlight-year">{{lowYear.year}}年 ({{lowYear.age}}岁)</text>
        <text class="highlight-score">{{lowYear.score}}分</text>
        <text class="highlight-ganzhi">{{lowYear.ganZhi}}</text>
      </view>
    </view>

    <!-- 大运解读 -->
    <view class="dayun-section">
      <view class="section-header">
        <text class="section-title">🎯 大运解读</text>
      </view>
      <view class="dayun-list">
        <view 
          wx:for="{{dayunAnalysis}}" 
          wx:key="start_age" 
          class="dayun-card"
          style="background: {{item.score >= 70 ? 'linear-gradient(135deg, rgba(34,197,94,0.1) 0%, rgba(20,40,20,0.2) 100%)' : item.score >= 50 ? 'linear-gradient(135deg, rgba(201,160,80,0.1) 0%, rgba(40,35,20,0.2) 100%)' : 'linear-gradient(135deg, rgba(239,68,68,0.1) 0%, rgba(40,20,20,0.2) 100%)'}}; border-color: {{item.score >= 70 ? 'rgba(34,197,94,0.3)' : item.score >= 50 ? 'rgba(201,160,80,0.3)' : 'rgba(239,68,68,0.3)'}};"
        >
          <view class="dayun-header">
            <view class="dayun-age">
              <text class="age-start">{{item.start_age}}</text>
              <text class="age-sep">-</text>
              <text class="age-end">{{item.end_age}}</text>岁
            </view>
            <view class="dayun-score" style="color: {{item.score >= 70 ? '#22c55e' : item.score >= 50 ? '#c9a050' : '#ef4444'}};">
              {{item.score}}分
            </view>
          </view>
          <view class="dayun-info">
            <text class="dayun-ganzhi">{{item.ganzhi}}</text>
            <text class="dayun-trend">{{item.trend_desc}}</text>
          </view>
          <view class="dayun-shen">
            <text wx:if="{{item.gan_shen}}" class="shen-tag">{{item.gan}}={{item.gan_shen}}</text>
            <text wx:if="{{item.zhi_shen}}" class="shen-tag">{{item.zhi}}={{item.zhi_shen}}</text>
          </view>
          <view class="dayun-tags">
            <text wx:for="{{item.key_points}}" wx:key="*this" class="tag-item">{{item}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 多维度分析 -->
    <view class="analysis-section">
      <view class="section-header">
        <text class="section-title">命理分析报告</text>
      </view>

      <!-- 总评 -->
      <view class="analysis-card analysis-summary">
        <view class="card-header-row">
          <text class="card-title">命理总评</text>
          <view class="score-badge" style="background: {{analysis.summaryScore >= 70 ? 'rgba(34,197,94,0.2)' : analysis.summaryScore >= 50 ? 'rgba(201,160,80,0.2)' : 'rgba(239,68,68,0.2)'}}; color: {{analysis.summaryScore >= 70 ? '#22c55e' : analysis.summaryScore >= 50 ? '#c9a050' : '#ef4444'}};">
            {{analysis.summaryScore}}分
          </view>
        </view>
        <text class="card-body">{{analysis.summary}}</text>
      </view>

      <!-- 性格 -->
      <view class="analysis-card">
        <view class="card-header-row">
          <text class="card-title">性格特质</text>
          <view class="score-badge" style="background: {{analysis.personalityScore >= 70 ? 'rgba(34,197,94,0.2)' : analysis.personalityScore >= 50 ? 'rgba(201,160,80,0.2)' : 'rgba(239,68,68,0.2)'}}; color: {{analysis.personalityScore >= 70 ? '#22c55e' : analysis.personalityScore >= 50 ? '#c9a050' : '#ef4444'}};">
            {{analysis.personalityScore}}分
          </view>
        </view>
        <text class="card-body">{{analysis.personality}}</text>
      </view>

      <!-- 事业 -->
      <view class="analysis-card">
        <view class="card-header-row">
          <text class="card-title">事业格局</text>
          <view class="score-badge" style="background: {{analysis.industryScore >= 70 ? 'rgba(34,197,94,0.2)' : analysis.industryScore >= 50 ? 'rgba(201,160,80,0.2)' : 'rgba(239,68,68,0.2)'}}; color: {{analysis.industryScore >= 70 ? '#22c55e' : analysis.industryScore >= 50 ? '#c9a050' : '#ef4444'}};">
            {{analysis.industryScore}}分
          </view>
        </view>
        <text class="card-body">{{analysis.industry}}</text>
      </view>

      <!-- 财运 -->
      <view class="analysis-card">
        <view class="card-header-row">
          <text class="card-title">财运分析</text>
          <view class="score-badge" style="background: {{analysis.wealthScore >= 70 ? 'rgba(34,197,94,0.2)' : analysis.wealthScore >= 50 ? 'rgba(201,160,80,0.2)' : 'rgba(239,68,68,0.2)'}}; color: {{analysis.wealthScore >= 70 ? '#22c55e' : analysis.wealthScore >= 50 ? '#c9a050' : '#ef4444'}};">
            {{analysis.wealthScore}}分
          </view>
        </view>
        <text class="card-body">{{analysis.wealth}}</text>
      </view>

      <!-- 婚姻 -->
      <view class="analysis-card">
        <view class="card-header-row">
          <text class="card-title">婚姻感情</text>
          <view class="score-badge" style="background: {{analysis.marriageScore >= 70 ? 'rgba(34,197,94,0.2)' : analysis.marriageScore >= 50 ? 'rgba(201,160,80,0.2)' : 'rgba(239,68,68,0.2)'}}; color: {{analysis.marriageScore >= 70 ? '#22c55e' : analysis.marriageScore >= 50 ? '#c9a050' : '#ef4444'}};">
            {{analysis.marriageScore}}分
          </view>
        </view>
        <text class="card-body">{{analysis.marriage}}</text>
      </view>

      <!-- 健康 -->
      <view class="analysis-card">
        <view class="card-header-row">
          <text class="card-title">健康提示</text>
          <view class="score-badge" style="background: {{analysis.healthScore >= 70 ? 'rgba(34,197,94,0.2)' : analysis.healthScore >= 50 ? 'rgba(201,160,80,0.2)' : 'rgba(239,68,68,0.2)'}}; color: {{analysis.healthScore >= 70 ? '#22c55e' : analysis.healthScore >= 50 ? '#c9a050' : '#ef4444'}};">
            {{analysis.healthScore}}分
          </view>
        </view>
        <text class="card-body">{{analysis.health}}</text>
      </view>

      <!-- 六亲 -->
      <view class="analysis-card">
        <view class="card-header-row">
          <text class="card-title">六亲缘分</text>
          <view class="score-badge" style="background: {{analysis.familyScore >= 70 ? 'rgba(34,197,94,0.2)' : analysis.familyScore >= 50 ? 'rgba(201,160,80,0.2)' : 'rgba(239,68,68,0.2)'}}; color: {{analysis.familyScore >= 70 ? '#22c55e' : analysis.familyScore >= 50 ? '#c9a050' : '#ef4444'}};">
            {{analysis.familyScore}}分
          </view>
        </view>
        <text class="card-body">{{analysis.family}}</text>
      </view>
    </view>

    <!-- 底部说明 -->
    <view class="footer-note">
      <text>人生K线仅供文化研究与娱乐参考，请勿迷信</text>
    </view>
  </block>

  <!-- 年份详情弹窗 -->
  <view wx:if="{{selectedPoint}}" class="detail-mask" bindtap="closeDetail">
    <view class="detail-popup" catchtap="closeDetail">
      <view class="detail-header">
        <view class="detail-header-left">
          <text class="detail-year">{{selectedPoint.year}} {{selectedPoint.ganZhi}}年</text>
          <text class="detail-age">{{selectedPoint.age}}岁 · {{selectedPoint.daYun}}</text>
        </view>
        <view class="detail-trend {{selectedPoint.close >= selectedPoint.open ? 'trend-up' : 'trend-down'}}">
          <text>{{selectedPoint.close >= selectedPoint.open ? '吉 ▲' : '凶 ▼'}}</text>
        </view>
      </view>
      <view class="detail-data-row">
        <view class="detail-data-item">
          <text class="data-label">开盘</text>
          <text class="data-value">{{selectedPoint.open}}</text>
        </view>
        <view class="detail-data-item">
          <text class="data-label">收盘</text>
          <text class="data-value">{{selectedPoint.close}}</text>
        </view>
        <view class="detail-data-item">
          <text class="data-label">最高</text>
          <text class="data-value">{{selectedPoint.high}}</text>
        </view>
        <view class="detail-data-item">
          <text class="data-label">最低</text>
          <text class="data-value">{{selectedPoint.low}}</text>
        </view>
        <view class="detail-data-item">
          <text class="data-label">评分</text>
          <text class="data-value data-score">{{selectedPoint.score}}</text>
        </view>
      </view>
      <view class="detail-reason">
        <text class="reason-label">运势批断</text>
        <text class="reason-text">{{selectedPoint.reason}}</text>
      </view>
      <view class="detail-close-btn" bindtap="closeDetail">
        <text>关闭</text>
      </view>
    </view>
  </view>
</view>
